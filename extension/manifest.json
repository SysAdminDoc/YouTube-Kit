{
  "manifest_version": 3,
  "name": "Astra Deck",
  "version": "3.6.2",
  "description": "Premium watch-page customization, split layouts, content controls, and local downloads for YouTube.",
  "author": "Matthew Parker",
  "homepage_url": "https://github.com/SysAdminDoc/YouTube-Kit",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Astra Deck",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "cookies",
    "downloads"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.youtube-nocookie.com/*",
    "https://youtu.be/*",
    "https://sponsor.ajay.app/*",
    "http://127.0.0.1:9751/*",
    "http://localhost:9751/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://*.youtube-nocookie.com/*",
        "https://youtu.be/*"
      ],
      "exclude_matches": [
        "https://m.youtube.com/*",
        "https://studio.youtube.com/*",
        "https://*.youtube.com/live_chat*"
      ],
      "css": [
        "early.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://*.youtube-nocookie.com/*",
        "https://youtu.be/*"
      ],
      "exclude_matches": [
        "https://m.youtube.com/*",
        "https://studio.youtube.com/*",
        "https://*.youtube.com/live_chat*"
      ],
      "js": [
        "ytkit-main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://*.youtube-nocookie.com/*",
        "https://youtu.be/*"
      ],
      "exclude_matches": [
        "https://m.youtube.com/*",
        "https://studio.youtube.com/*",
        "https://*.youtube.com/live_chat*"
      ],
      "js": [
        "core/env.js",
        "core/storage.js",
        "core/styles.js",
        "core/url.js",
        "core/page.js",
        "core/navigation.js",
        "core/player.js",
        "ytkit.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://*.youtube.com/live_chat*"
      ],
      "exclude_matches": [
        "https://m.youtube.com/*",
        "https://studio.youtube.com/*"
      ],
      "js": [
        "core/env.js",
        "core/storage.js",
        "core/styles.js",
        "core/url.js",
        "core/page.js",
        "core/navigation.js",
        "core/player.js",
        "ytkit.js"
      ],
      "all_frames": true,
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "https://*.youtube.com/*",
        "https://*.youtube-nocookie.com/*",
        "https://youtu.be/*"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "commands": {
    "toggle-control-center": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Toggle the Astra Deck control center on the current YouTube tab"
    }
  }
}
